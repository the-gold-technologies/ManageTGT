datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --- NextAuth Models ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?

  // Custom fields for AgencyOS
  roleId String?
  role   Role?   @relation(fields: [roleId], references: [id], onDelete: SetNull)

  accounts Account[]
  sessions Session[]

  // Domain relations
  projectsLed     Project[]      @relation("TeamLead")
  tasksAssignedBy Task[]         @relation("AssignedBy")
  activityLogs    ActivityLog[]  @relation("PerformedBy")
  salesClosures   SalesClosure[] @relation("ClosedBy")
  notifications   Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- AgencyOS Domain Models ---

// --- Dynamic Configuration Models ---

model ServiceType {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Role {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  isSystem    Boolean @default(false)

  users       User[]
  permissions RoleModuleAccess[]

  createdAt DateTime @default(now())
}

model RoleModuleAccess {
  id     String @id @default(cuid())
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  moduleKey String
  hasAccess Boolean @default(false)

  @@unique([roleId, moduleKey])
}

enum ProjectStatus {
  pending
  in_progress
  on_hold
  delivered
  completed
}

enum TaskStatus {
  todo
  in_progress
  review
  completed
}

enum Priority {
  low
  medium
  high
  urgent
}

enum InvoiceStatus {
  paid
  partially_paid
  pending
  overdue
}

enum PaymentMode {
  bank_transfer
  upi
  cash
  cheque
  card
  other
}

enum ExpenseType {
  freelancer
  designer
  developer
  advertising
  travel
  software
  hosting
  miscellaneous
}

enum FileCategory {
  brand_assets
  reference
  deliverable
  contract
  invoice_docs
  content
  bill_receipt
  general
}

model Client {
  id             String  @id @default(cuid())
  name           String
  company_name   String?
  contact_person String?
  mobile         String?
  email          String?
  address        String?
  gst_number     String?
  pan_number     String?
  notes          String? @db.Text
  createdBy      String?
  document_urls  String[] @default([])

  projects      Project[]
  invoices      Invoice[]
  salesClosures SalesClosure[]
  fileRecords   FileRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum BillingCycle {
  ONE_TIME
  MONTHLY
  ANNUAL
}

model Project {
  id                  String        @id @default(cuid())
  project_code        String        @unique
  name                String
  client_id           String?
  client              Client?       @relation(fields: [client_id], references: [id], onDelete: SetNull)
  service_type        String
  quoted_price        Float
  billing_cycle       BillingCycle  @default(ONE_TIME)
  next_billing_date   DateTime?
  start_date          DateTime?
  expected_completion DateTime?
  team_lead_id        String?
  teamLead            User?         @relation("TeamLead", fields: [team_lead_id], references: [id], onDelete: SetNull)
  assigned_member_ids String[]      @default([])
  status              ProjectStatus @default(pending)
  delivery_date       DateTime?
  completion_date     DateTime?
  deliverable_urls    String[]      @default([])
  created_by          String?
  notes               String?       @db.Text

  tasks         Task[]
  invoices      Invoice[]
  expenses      Expense[]
  activityLogs  ActivityLog[]
  salesClosures SalesClosure[]
  fileRecords   FileRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([client_id])
}

model Task {
  id              String     @id @default(cuid())
  project_id      String?
  project         Project?   @relation(fields: [project_id], references: [id], onDelete: Cascade)
  title           String
  description     String?    @db.Text
  assigned_by     String?
  assigner        User?      @relation("AssignedBy", fields: [assigned_by], references: [id], onDelete: SetNull)
  assigned_member_ids String[] @default([])
  deadline        DateTime?
  completion_date DateTime?
  status          TaskStatus @default(todo)
  priority        Priority   @default(medium)

  files TaskFile[]
  logs  ActivityLog[]
  subtasks Subtask[]
  fileRecords FileRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([project_id])
}

model Subtask {
  id           String   @id @default(cuid())
  task_id      String
  task         Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)
  title        String
  is_completed Boolean  @default(false)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([task_id])
}

model TaskFile {
  id          String   @id @default(cuid())
  task_id     String
  task        Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)
  file_name   String
  file_url    String
  file_size   Int?
  uploaded_by String?
  uploaded_at DateTime @default(now())
}

model ActivityLog {
  id           String   @id @default(cuid())
  task_id      String?
  task         Task?    @relation(fields: [task_id], references: [id], onDelete: Cascade)
  project_id   String?
  project      Project? @relation(fields: [project_id], references: [id], onDelete: Cascade)
  action       String
  performed_by String?
  performer    User?    @relation("PerformedBy", fields: [performed_by], references: [id], onDelete: SetNull)
  metadata     Json?
  performed_at DateTime @default(now())

  @@index([task_id])
  @@index([project_id])
}

model Invoice {
  id              String        @id @default(cuid())
  invoice_number  String        @unique
  project_id      String?
  project         Project?      @relation(fields: [project_id], references: [id], onDelete: SetNull)
  client_id       String?
  client          Client?       @relation(fields: [client_id], references: [id], onDelete: SetNull)
  quoted_value    Float
  final_billing   Float
  amount_received Float         @default(0)
  invoice_date    DateTime
  due_date        DateTime?
  payment_date    DateTime?
  payment_mode    PaymentMode?
  status          InvoiceStatus @default(pending)
  notes           String?       @db.Text
  created_by      String?
  file_urls       String[]      @default([])
  gst_applied     Boolean       @default(false)
  payments        InvoicePayment[]
  fileRecords     FileRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([project_id])
  @@index([client_id])
}

model InvoicePayment {
  id           String      @id @default(cuid())
  invoice_id   String
  invoice      Invoice     @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  amount       Float
  payment_date DateTime
  payment_mode PaymentMode
  notes        String?     @db.Text
  recorded_by  String?
  
  createdAt DateTime @default(now())

  @@index([invoice_id])
}

model Expense {
  id           String      @id @default(cuid())
  project_id   String?
  project      Project?    @relation(fields: [project_id], references: [id], onDelete: Cascade)
  expense_type ExpenseType
  description  String?     @db.Text
  amount       Float
  date         DateTime
  bill_urls    String[]    @default([])
  created_by   String?
  fileRecords  FileRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expense_type])
  @@index([project_id])
}

model SalesTarget {
  id           String  @id @default(cuid())
  service_type String
  month        Int
  year         Int
  target_count Int
  average_cost Float   @default(0)
  created_by   String?

  createdAt DateTime @default(now())

  @@unique([service_type, month, year])
}

model SalesClosure {
  id         String   @id @default(cuid())
  target_id  String
  closed_by  String?
  closer     User?    @relation("ClosedBy", fields: [closed_by], references: [id], onDelete: SetNull)
  client_id  String?
  client     Client?  @relation(fields: [client_id], references: [id], onDelete: SetNull)
  project_id String?
  project    Project? @relation(fields: [project_id], references: [id], onDelete: SetNull)
  closed_at  DateTime @default(now())
  notes      String?  @db.Text

  @@index([target_id])
  @@index([project_id])
  @@index([client_id])
}

model Notification {
  id        String   @id @default(cuid())
  user_id   String
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String   @db.Text
  link      String?
  is_read   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([user_id])
  @@index([is_read])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([token])
}

// --- Calendar Models ---

enum CalendarEventType {
  meeting
  reminder
  milestone
  leave
  custom
}

model CalendarEvent {
  id           String            @id @default(cuid())
  type         CalendarEventType @default(custom)
  title        String
  description  String?           @db.Text
  start_date   DateTime
  end_date     DateTime?
  all_day      Boolean           @default(false)
  color        String?
  attendee_ids String[]          @default([])
  created_by   String?
  is_cancelled Boolean           @default(false)
  // Optional link back to a source entity
  source_type  String?           // 'task' | 'project' | 'invoice' | 'prospect'
  source_id    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([start_date])
  @@index([created_by])
}

model Prospect {
  id                       String    @id @default(cuid())
  name                     String
  email                    String
  mobile                   String?
  company_name             String?
  proposal_submitted       Boolean   @default(false)
  proposal_submission_date DateTime?
  quote_submitted          Float?
  client_converted         Boolean   @default(false)
  services                 String[]  @default([])
  comments                 String?   @db.Text
  document_urls            String[]  @default([])
  fileRecords              FileRecord[]
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
}

// --- File Manager ---

model FileRecord {
  id            String       @id @default(cuid())

  // File info
  name          String
  storage_path  String
  url           String
  size          Int?
  mime_type     String?
  category      FileCategory @default(general)

  // Source metadata
  source_date   DateTime?
  source_note   String?   @db.Text

  // Context — belongs to one of these
  client_id     String?
  client        Client?   @relation(fields: [client_id], references: [id], onDelete: Cascade)
  project_id    String?
  project       Project?  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  prospect_id   String?
  prospect      Prospect? @relation(fields: [prospect_id], references: [id], onDelete: Cascade)
  task_id       String?
  task          Task?     @relation(fields: [task_id], references: [id], onDelete: Cascade)
  invoice_id    String?
  invoice       Invoice?  @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  expense_id    String?
  expense       Expense?  @relation(fields: [expense_id], references: [id], onDelete: Cascade)

  // Versioning
  version       Int       @default(1)
  parent_id     String?

  // Uploader
  uploaded_by   String?
  uploader_name String?

  // Access control — user IDs this file is shared with (admin sees all)
  shared_with   String[]  @default([])

  is_archived   Boolean   @default(false)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([client_id])
  @@index([project_id])
  @@index([prospect_id])
  @@index([task_id])
  @@index([invoice_id])
  @@index([expense_id])
  @@index([parent_id])
  @@index([uploaded_by])
}
